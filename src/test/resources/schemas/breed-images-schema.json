{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["message", "status"],
  "properties": {
    "message": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "status": {
      "type": "string",
      "enum": ["success"]
    }
  },
  "additionalProperties": false
}